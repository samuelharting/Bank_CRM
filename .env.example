DATABASE_URL=postgresql://user:password@localhost:5432/deerwood_crm

# Local dev only — pick a seeded user instead of Entra ID. Never enable in production.
# API: requires NODE_ENV !== production. Web: requires VITE_ prefix.
DEV_AUTH_BYPASS=true
VITE_DEV_AUTH_BYPASS=true

VITE_AZURE_CLIENT_ID=your-client-id
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_API_URL=http://localhost:7071/api
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_ID=your-tenant-id
ALLOWED_ORIGIN=http://localhost:5173
ANTHROPIC_API_KEY=your-anthropic-api-key
# ZhipuAI / Z.AI key — used for AI search if set (takes priority over Anthropic)
# ZHIPU_API_KEY=your-zhipu-api-key
# Optional: model code (default glm-4.7-flash). See https://docs.z.ai/api-reference/llm/chat-completion
# ZHIPU_MODEL=glm-4.7-flash
# Optional: override base URL if Z.AI changes their general chat endpoint
# ZHIPU_API_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions
# Optional: enable public web enrichment for AI prep briefs (default true)
# AI_WEB_SEARCH_ENABLED=true
AZURE_CLIENT_SECRET=your-client-secret
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id

# Document storage (Phase 2) — optional: local filesystem used if not set
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=lead-documents
# LOCAL_DOCUMENT_STORAGE_DIR=.local-document-storage
# MAX_UPLOAD_BYTES=15728640

# Excel import (Phase 3) — optional
# LOCAL_IMPORT_TEMP_DIR=.import-temp
# MAX_IMPORT_ROWS=500
# MAX_IMPORT_PREVIEW_BYTES=5242880
